if __name__ == "__main__":   # FIXED
    # Create the CBR system
    cbr_system = CaseBasedReasoning()

    # Add past cases
    cbr_system.add_case([2.0, 3.0], 'A')
    cbr_system.add_case([1.0, 1.0], 'B')
    cbr_system.add_case([4.0, 5.0], 'A')
    cbr_system.add_case([3.0, 2.0], 'B')

    # Query case
    query_case = [2.5, 3.5]

    # Retrieve similar cases
    similar_cases = cbr_system.retrieve(query_case, k=2)
    print("Most similar cases:")
    for dist, label in similar_cases:
        print(f"Distance: {dist:.2f}, Label: {label}")

    # Make a prediction
    prediction = cbr_system.predict(query_case, k=2)
    print(f"Predicted label: {prediction}")
